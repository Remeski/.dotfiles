From 5480730a5ac16cf7105880b286ea27751de284a3 Mon Sep 17 00:00:00 2001
From: Remesk1 <eeliremes@gmail.com>
Date: Tue, 14 Jul 2026 21:43:25 +0300
Subject: [PATCH] enable natural scroll on touchpad devices

on config.h you should set natural_scrolling = 0 since that is for other
devices.
---
 dwl.c | 3 +++
 1 file changed, 3 insertions(+)

diff --git a/dwl.c b/dwl.c
index 101a45f..9a03945 100644
--- a/dwl.c
+++ b/dwl.c
@@ -1155,6 +1155,9 @@ createpointer(struct wlr_pointer *pointer)
 		if (libinput_device_config_scroll_has_natural_scroll(device))
 			libinput_device_config_scroll_set_natural_scroll_enabled(device, natural_scrolling);
 
+		if (libinput_device_config_tap_get_finger_count(device) > 1)
+			libinput_device_config_scroll_set_natural_scroll_enabled(device, 1);
+
 		if (libinput_device_config_dwt_is_available(device))
 			libinput_device_config_dwt_set_enabled(device, disable_while_typing);
 
-- 
